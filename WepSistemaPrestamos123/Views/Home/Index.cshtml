@{
    ViewData["Title"] = "Home Page";
    Layout = "_Layout";
}

<link href="~/lib/Home/css/home.css" rel="stylesheet" />

<!-- Loader -->
<div id="loader" class="loader-container">
    <div class="loader-spinner"></div>
</div>

<div class="container-fluid py-3">
    <div class="row justify-content-center">
        <div class="col-lg-10">

            <!-- Header bienvenida -->
            <div class="modulo-header">
                <h1 class="animated-title">
                    <i class="bi bi-bank2 me-2"></i>
                    Bienvenido al Sistema de Préstamos
                </h1>
                <p>Gestione, solicite y consulte sus préstamos de forma fácil y segura</p>
            </div>

            <!-- Card principal -->
            <div class="card-master home-card">
                <div class="card-header-custom">
                    <i class="bi bi-ui-checks-grid"></i>
                    <span>¿Qué desea hacer hoy?</span>
                </div>
                <div class="card-content">

                    <!-- Opciones de acción -->
                    <div class="row g-3 mb-4">
                        <div class="col-md-4">
                            <div class="home-opcion">
                                <div class="home-opcion-icono icono-navy">
                                    <i class="bi bi-search"></i>
                                </div>
                                <div class="home-opcion-texto">
                                    <div class="home-opcion-titulo">Consultar Solicitudes</div>
                                    <div class="home-opcion-sub">Revisa el historial de solicitudes realizadas</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="home-opcion">
                                <div class="home-opcion-icono icono-dorado">
                                    <i class="bi bi-pencil-square"></i>
                                </div>
                                <div class="home-opcion-texto">
                                    <div class="home-opcion-titulo">Nueva Solicitud</div>
                                    <div class="home-opcion-sub">Crea una nueva solicitud de préstamo</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="home-opcion">
                                <div class="home-opcion-icono icono-outline">
                                    <i class="bi bi-bar-chart-line"></i>
                                </div>
                                <div class="home-opcion-texto">
                                    <div class="home-opcion-titulo">Ver Estado</div>
                                    <div class="home-opcion-sub">Consulta el estado de tu solicitud actual</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <hr class="divisor-datos" />

                    <!-- Tip de uso -->
                    <div class="home-tip">
                        <i class="bi bi-lightbulb-fill home-tip-icono"></i>
                        <span>Use el menú lateral para acceder a cada módulo del sistema.</span>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/Home/js/Home.js"></script>
}
