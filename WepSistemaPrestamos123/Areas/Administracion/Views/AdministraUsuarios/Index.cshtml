@using Comun.DTO.Generales
@{
    Layout = "_Layout";
    ViewData["Title"] = "Administrar Usuarios";
    var rolesDisponibles = ViewBag.Roles as SelectList;
}

<link href="~/lib/Administracion/css/AdministracionStyles.css" rel="stylesheet" />

<div class="container-fluid py-3">
    <div class="row justify-content-center">
        <div class="col-lg-10">

            <!-- Header del módulo -->
            <div class="modulo-header">
                <h1>
                    <i class="bi bi-shield-lock-fill me-2"></i>
                    Gestión de Roles de Usuario
                </h1>
                <p>Busca un funcionario por identificación y gestiona sus roles de acceso</p>
            </div>

            <!-- Barra de búsqueda -->
            <div class="busqueda-wrapper">
                <div class="row align-items-center g-2">
                    <div class="col-12 col-md-9">
                        <input type="text" id="nroIdentificacion" class="form-control"
                               placeholder="Buscar funcionario por número de identificación..." />
                    </div>
                    <div class="col-12 col-md-3">
                        <button id="btnBuscar" class="btn-buscar">
                            <i class="bi bi-search"></i> Buscar
                        </button>
                    </div>
                </div>
            </div>

            <!-- Resultado del usuario -->
            <div id="resultadoUsuario" class="card d-none">

                <!-- Header de la card -->
                <div class="card-header-custom">
                    <i class="bi bi-person-badge-fill"></i>
                    <span>Información del Funcionario</span>
                </div>

                <div class="card-body">
                    <div class="card-content">
                        <div class="row">

                         
                            <!-- Foto -->
                            <div class="col-12 col-md-4 col-lg-3 text-center mb-3 mb-md-0 d-flex align-items-start justify-content-center pt-2">
                                <img id="fotoUsuario" src="" class="foto-usuario" alt="Foto del usuario" />
                            </div>

                            <!-- Datos -->
                            
                            <div class="col-12 col-md-8 col-lg-9">

                            <!-- Datos -->
                            <div class="col-md-9">

                                <div class="row mb-2">
                                    <div class="col-sm-4 dato-label">Nombre completo</div>
                                    <div class="col-sm-8 dato-valor" id="nombreUsuario"></div>
                                </div>
                                <div class="row mb-2">
                                    <div class="col-sm-4 dato-label">Usuario</div>
                                    <div class="col-sm-8 dato-valor" id="usuarioEmpresarial"></div>
                                </div>
                                <div class="row mb-2">
                                    <div class="col-sm-4 dato-label">Identificación</div>
                                    <div class="col-sm-8 dato-valor" id="identificacionUsuario"></div>
                                </div>
                                <div class="row mb-3">
                                    <div class="col-sm-4 dato-label">Teléfono</div>
                                    <div class="col-sm-8 dato-valor" id="telefonoUsuario"></div>
                                </div>

                                <hr class="divisor-datos" />

                                <!-- Roles asignados -->
                                <div class="mb-3">
                                    <div class="roles-titulo">
                                        <i class="bi bi-tags-fill"></i> Roles asignados
                                    </div>
                                    <ul id="listaRoles"></ul>
                                    <p id="sinRoles" class="d-none">
                                        Este usuario aún no tiene roles asignados.
                                    </p>
                                </div>

                                <hr class="divisor-datos" />

                                <!-- Gestión de roles -->
                                <div class="mb-3">
                                    <label class="form-label-custom">Selecciona un rol</label>
                                    <select id="rolSeleccionado" class="form-select">
                                        <option value="">-- Selecciona un rol --</option>
                                        @if (rolesDisponibles != null)
                                        {
                                            @foreach (var item in rolesDisponibles)
                                            {
                                                <option value="@item.Value">@item.Text</option>
                                            }
                                        }
                                    </select>
                                </div>

                                <input type="hidden" id="idUsuarioActual" value="" />

                                <div class="d-flex gap-2 justify-content-end">
                                    <button id="btnAsignar" class="btn-asignar">
                                        <i class="bi bi-plus-circle me-1"></i> Asignar Rol
                                    </button>
                                    <button id="btnQuitar" class="btn-quitar">
                                        <i class="bi bi-trash me-1"></i> Quitar Rol
                                    </button>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/lib/Administracion/js/AdministrarUsuarios.js"></script>
}


















