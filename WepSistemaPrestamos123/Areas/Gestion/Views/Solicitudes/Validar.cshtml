@using Comun.DTO.Solicitud
@model Respuesta_Consulta_Solicitudes_Prestamo_Dto;

@{
    Layout = "_Layout";
    ViewData["Title"] = "Ver Solicitud";
    var documentos = Model.Documentos;
}

<link href="~/lib/Soliciud/css/validar.css" rel="stylesheet" />

<div class="container py-3">
    <div class="row justify-content-center">
        <div class="col-lg-11">

            <!-- Header del módulo -->
            <div class="modulo-header">
                <h1>
                    <i class="bi bi-layout-text-window-reverse me-2"></i>
                    Validar Solicitud de Préstamo
                </h1>
                <p>Sistema de Préstamos Florencia</p>
            </div>

            <!-- Alerta informativa -->
            <div class="alerta-info mb-3">
                <i class="bi bi-info-circle-fill me-2"></i>
                A continuación encontrarás de forma agrupada la información presentada por el
                solicitante al momento de registrar su solicitud.
            </div>

            <!-- Botón Atrás -->
            <div class="mb-3">
                <button type="button" class="btn-volver" onclick="volverConRecarga()">
                    <i class="bi bi-arrow-left me-2"></i> Atrás
                </button>
            </div>

            <!-- Card con Tabs -->
            <div class="card-master">

                <!-- Tabs Header -->
                <div class="tabs-header">
                    <ul class="nav nav-tabs nav-fill tabs-nav" id="mainTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="tab-btn active" id="home-tab"
                                    data-bs-toggle="tab" data-bs-target="#info-personal-panel"
                                    type="button" role="tab">
                                <i class="bi bi-person-bounding-box me-2"></i> Personal
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="tab-btn" id="profile-tab"
                                    data-bs-toggle="tab" data-bs-target="#contacto-panel"
                                    type="button" role="tab">
                                <i class="bi bi-person-lines-fill me-2"></i> Contacto
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="tab-btn" id="contact-tab"
                                    data-bs-toggle="tab" data-bs-target="#finanzas-panel"
                                    type="button" role="tab">
                                <i class="bi bi-cash-coin me-2"></i> Financiera
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="tab-btn" id="settings-tab"
                                    data-bs-toggle="tab" data-bs-target="#documentos-panel"
                                    type="button" role="tab">
                                <i class="bi bi-paperclip me-2"></i> Documentos
                            </button>
                        </li>
                    </ul>
                </div>

                <!-- Tabs Content -->
                <div class="card-content">
                    <div class="tab-content" id="mainTabsContent">

                        <!-- ===== TAB PERSONAL ===== -->
                        <div class="tab-pane fade show active" id="info-personal-panel" role="tabpanel">
                            <fieldset disabled>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label-custom">Primer Nombre</label>
                                        <input type="text" class="form-input"
                                               value="@(Model.PrimerNombreSolicitante ?? string.Empty)" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label-custom">Segundo Nombre</label>
                                        <input type="text" class="form-input"
                                               value="@(Model.SegundoNombreSolicitante ?? string.Empty)" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label-custom">Primer Apellido</label>
                                        <input type="text" class="form-input"
                                               value="@(Model.PrimerApellidoSolicitante ?? string.Empty)" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label-custom">Segundo Apellido</label>
                                        <input type="text" class="form-input"
                                               value="@(Model.SegundoApellidoSolicitante ?? string.Empty)" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label-custom">Tipo de Documento</label>
                                        @Html.DropDownListFor(m => m.TipoIdentificacionId,
                                            ViewBag.listTipoDocumentos as SelectList,
                                            "Seleccione ...",
                                            new {
                                                @class = "form-input form-select-custom",
                                                id = "listTipoDocumentos"
                                            })
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label-custom">Identificación</label>
                                        <input type="number" class="form-input"
                                               value="@(Model.NumeroIdentificacion.ToString() ?? "")" />
                                    </div>
                                </div>
                            </fieldset>
                        </div>

                        <!-- ===== TAB CONTACTO ===== -->
                        <div class="tab-pane fade" id="contacto-panel" role="tabpanel">
                            <fieldset disabled>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label-custom">Correo Electrónico</label>
                                        <input type="email" class="form-input"
                                               value="@(Model.Email ?? string.Empty)" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label-custom">Celular</label>
                                        <input type="tel" class="form-input"
                                               value="@(Model.Celular.ToString() ?? "")" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label-custom">Departamento de Residencia</label>
                                        @Html.DropDownListFor(m => m.DepartamentoResidenciaId,
                                            ViewBag.ListaDepartamentos as SelectList,
                                            "Seleccione ...",
                                            new {
                                                @class = "form-input form-select-custom",
                                                id = "ListaDepartamentos"
                                            })
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label-custom">Municipio de Residencia</label>
                                        @Html.DropDownListFor(m => m.MunicipioResidenciaId,
                                            ViewBag.ListaMunicipios as SelectList,
                                            "Seleccione ...",
                                            new {
                                                @class = "form-input form-select-custom",
                                                id = "ListaMunicipios"
                                            })
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label-custom">Barrio de Residencia</label>
                                        @Html.DropDownListFor(m => m.BarrioResidenciaId,
                                            ViewBag.ListaBarrios as SelectList,
                                            "Seleccione ...",
                                            new {
                                                @class = "form-input form-select-custom",
                                                id = "ListaBarrios"
                                            })
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label-custom">Dirección de Residencia</label>
                                        <input type="text" class="form-input"
                                               value="@(Model.DireccionResidencia ?? string.Empty)" />
                                    </div>
                                </div>
                            </fieldset>
                        </div>

                        <!-- ===== TAB FINANCIERA ===== -->
                        <div class="tab-pane fade" id="finanzas-panel" role="tabpanel">
                            <fieldset disabled>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label-custom">Tipo de Documento</label>
                                        @Html.DropDownListFor(m => m.TipoIdentificacionId,
                                            ViewBag.listTipoDocumentos as SelectList,
                                            "Seleccione ...",
                                            new {
                                                @class = "form-input form-select-custom",
                                                id = "listTipoDocumentosFinanzas"
                                            })
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label-custom">Tipo de Cuenta</label>
                                        <select class="form-input form-select-custom" id="tipoCuenta">
                                            <option value="">Seleccione una opción...</option>
                                            <option value="1">Cuenta de Ahorros</option>
                                            <option value="2">Cuenta Corriente</option>
                                        </select>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label-custom">Número de Cuenta</label>
                                        <input type="text" class="form-input"
                                               value="111-000-22111" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label-custom">Código de Acceso</label>
                                        <input type="text" class="form-input"
                                               value="@(Model.CodigoAcceso.ToString() ?? "")" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label-custom">Monto Solicitado</label>
                                        <input type="number" class="form-input"
                                               value="@(Model.Monto.ToString() ?? "")" />
                                    </div>
                                </div>
                            </fieldset>
                        </div>

                        <!-- ===== TAB DOCUMENTOS ===== -->
                        <div class="tab-pane fade" id="documentos-panel" role="tabpanel">
                            <div class="card-master">
                                <div class="card-header-custom">
                                    <i class="bi bi-paperclip"></i>
                                    <span>Documentos Adjuntados</span>
                                </div>
                                <div class="card-content">
                                    <div class="table-responsive">
                                        <table id="tablaSolicitudesRevision"
                                               class="tabla-master table table-hover table-sm">
                                            <thead>
                                                <tr>
                                                    <th class="text-center">Ver</th>
                                                    <th>Nombre</th>
                                                    <th>Tamaño</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @if (documentos != null && documentos.Any())
                                                {
                                                    @foreach (var doc in documentos)
                                                    {
                                                        <tr>
                                                            <td class="text-center">
                                                                <button class="btn-accion-ver verDoc"
                                                                        title="Ver"
                                                                        data="@doc.ContenidoDoc.ToString()">
                                                                    <i class="bi bi-eye-fill"></i>
                                                                </button>
                                                            </td>
                                                            <td>@doc.IdDocumento</td>
                                                            <td>@doc.Tamanio</td>
                                                        </tr>
                                                    }
                                                }
                                                else
                                                {
                                                    <tr>
                                                        <td colspan="3" class="tabla-vacia">
                                                            <i class="bi bi-inbox me-2"></i>
                                                            No se encontraron documentos adjuntos.
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- Modal Ver Documento -->
<div class="modal fade" id="modalVerDocumento" tabindex="-1"
     aria-labelledby="modalVerDocumentoLabel">
    <div class="modal-dialog modal-xl">
        <div class="modal-content modal-master">

            <div class="modal-header-master">
                <h5 class="modal-titulo">
                    <i class="bi bi-file-earmark-text me-2"></i> Ver Documento
                </h5>
                <button type="button" class="btn-close btn-close-white"
                        data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>

            <div class="modal-body p-0">
                <div id="contenedorDocumento"
                     style="width:100%; min-height:600px; display:flex;
                            align-items:center; justify-content:center;">
                </div>
            </div>

            <div class="modal-footer modal-footer-master">
                <button type="button" class="btn-peligro" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle me-1"></i> Cerrar
                </button>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/Soliciud/js/Validar.js"></script>
}
