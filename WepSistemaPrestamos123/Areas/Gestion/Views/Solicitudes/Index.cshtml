@using Comun.DTO.Solicitud
@{
    Layout = "_Layout";
    ViewData["Title"] = "Gestión de Solicitudes";

    var solicitudes = ViewBag.listSolregis as List<Respuesta_Consulta_Solicitudes_Prestamo_Dto> ?? new List<Respuesta_Consulta_Solicitudes_Prestamo_Dto>();
    var solicitudesRevi = ViewBag.listSolRevis as List<Respuesta_Consulta_Solicitudes_Prestamo_Dto> ?? new List<Respuesta_Consulta_Solicitudes_Prestamo_Dto>();
    var solicitudesFull = ViewBag.listSolFull as List<Respuesta_Consulta_Solicitudes_Prestamo_Dto> ?? new List<Respuesta_Consulta_Solicitudes_Prestamo_Dto>();
}

<link href="~/lib/Soliciud/CSS/solicitudes.css" rel="stylesheet" />

<div class="container-fluid py-3">
    <div class="row justify-content-center">
        <div class="col-lg-11">

            <!-- Header del módulo -->
            <div class="modulo-header">
                <h1>
                    <i class="bi bi-layout-text-window-reverse me-2"></i>
                    Gestión de Solicitudes de Préstamos
                </h1>
                <p>Sistema de Préstamos Florencia</p>
            </div>

            <!-- Card con Tabs -->
            <div class="card-master">

                <!-- Tabs Header -->
                <div class="tabs-header">
                    <ul class="nav nav-tabs nav-fill tabs-nav" id="mainTabs" role="tablist">
                   
                        <li class="nav-item" role="presentation">
                            <button class="tab-btn active" id="home-tab"
                                    data-bs-toggle="tab" data-bs-target="#home-tab-pane"
                                    type="button" role="tab">
                                <i class="bi bi-house-door me-2"></i> Inicio
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="tab-btn" id="profile-tab"
                                    data-bs-toggle="tab" data-bs-target="#profile-tab-pane"
                                    type="button" role="tab">
                                <i class="bi bi-journal-arrow-down me-2"></i> Llegadas
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="tab-btn" id="contact-tab"
                                    data-bs-toggle="tab" data-bs-target="#contact-tab-pane"
                                    type="button" role="tab">
                                <i class="bi bi-envelope me-2"></i> En Revisión
                            </button>
                        </li>
                    </ul>
                </div>

                <!-- Tabs Content -->
                <div class="card-content">
                    <div class="tab-content" id="mainTabsContent">

                        <!-- ===== TAB INICIO ===== -->
                        <div class="tab-pane fade show active" id="home-tab-pane" role="tabpanel">

                            <!-- Alerta informativa -->
                            <div class="alerta-info mb-4">
                                <i class="bi bi-info-circle-fill me-2"></i>
                                Bienvenido al panel de gestión de solicitudes de préstamos. Aquí encontrarás
                                un resumen de las solicitudes gestionadas y recientes de esta vigencia.
                            </div>

                            <!-- Tarjetas de resumen -->
                            <div class="row g-3 mb-4">
                                <div class="col-md-4">
                                    <div class="stat-card stat-card-navy">
                                        <i class="bi bi-card-list stat-icon"></i>
                                        <div class="stat-numero" id="countAllRequest">@(solicitudesFull?.Count() ?? 0)</div>
                                        <div class="stat-titulo">Total Solicitudes</div>
                                        <div class="stat-sub">Total registradas</div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="stat-card stat-card-dorado">
                                        <i class="bi bi-graph-up stat-icon"></i>
                                        <div class="stat-numero">@(solicitudes?.Count() ?? 0)</div>
                                        <div class="stat-titulo">Registradas</div>
                                        <div class="stat-sub">Pendientes por revisar</div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="stat-card stat-card-outline">
                                        <i class="bi bi-card-checklist stat-icon"></i>
                                        <div class="stat-numero">@(solicitudesRevi?.Count() ?? 0)</div>
                                        <div class="stat-titulo">En Revisión</div>
                                        <div class="stat-sub">Validando requisitos</div>
                                    </div>
                                </div>
                            </div>

                            <!-- Actividad reciente -->
                            <div class="card-master">
                                <div class="card-header-custom">
                                    <i class="bi bi-activity"></i>
                                    <span>Actividad Reciente</span>
                                </div>
                                <div class="card-content">
                                    <div class="actividad-lista">
                                        <div class="actividad-item">
                                            <i class="bi bi-person-plus actividad-icon icon-exito"></i>
                                            <span>Nuevo usuario registrado</span>
                                            <span class="actividad-tiempo">Hace 2 min</span>
                                        </div>
                                        <div class="actividad-item">
                                            <i class="bi bi-cart-check actividad-icon icon-navy"></i>
                                            <span>Pedido completado #1234</span>
                                            <span class="actividad-tiempo">Hace 5 min</span>
                                        </div>
                                        <div class="actividad-item">
                                            <i class="bi bi-exclamation-triangle actividad-icon icon-dorado"></i>
                                            <span>Stock bajo en producto ABC</span>
                                            <span class="actividad-tiempo">Hace 15 min</span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>

                        <!-- ===== TAB LLEGADAS ===== -->
                        <div class="tab-pane fade" id="profile-tab-pane" role="tabpanel">
                            <div class="card-master">
                                <div class="card-header-custom">
                                    <i class="bi bi-journal-arrow-down"></i>
                                    <span>Solicitudes de Préstamos Llegadas</span>
                                </div>
                                <div class="card-content">
                                    <div class="table-responsive">
                                        <table id="datatablesSimple" class="tabla-master table table-hover table-sm">
                                            <thead>
                                                <tr>
                                                    <th class="text-center">Acciones</th>
                                                    <th>Solicitante</th>
                                                    <th>Identificación</th>
                                                    <th>Celular</th>
                                                    <th>Fecha Solicitud</th>
                                                    <th>Monto</th>
                                                    <th>Estado</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @if (solicitudes != null && solicitudes.Any())
                                                {
                                                    @foreach (var solicitud in solicitudes)
                                                    {
                                                        <tr>
                                                            <td class="text-center">
                                                                <div class="d-flex gap-1 justify-content-center">
                                                                    <button class="btn-accion-ver" title="Ver"
                                                                            onclick="verSolicitud(@solicitud.Id, @solicitud.EstadoId)">
                                                                        <i class="bi bi-eye-fill"></i>
                                                                    </button>
                                                                </div>
                                                            </td>
                                                            <td>@solicitud.NombreCompleto</td>
                                                            <td>@solicitud.NumeroIdentificacion.ToString("N0")</td>
                                                            <td>@solicitud.Celular</td>
                                                            <td>@solicitud.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</td>
                                                            <td>@(solicitud.Monto.ToString("C", new System.Globalization.CultureInfo("es-CO")) ?? "N/A")</td>
                                                            <td><span class="badge-pendiente">Registrada</span></td>
                                                        </tr>
                                                    }
                                                }
                                                else
                                                {
                                                    <tr>
                                                        <td colspan="7" class="tabla-vacia">
                                                            <i class="bi bi-inbox me-2"></i> No se encontraron solicitudes.
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ===== TAB EN REVISIÓN ===== -->
                        <div class="tab-pane fade" id="contact-tab-pane" role="tabpanel">
                            <div class="card-master">
                                <div class="card-header-custom">
                                    <i class="bi bi-envelope"></i>
                                    <span>Solicitudes en Revisión</span>
                                </div>
                                <div class="card-content">
                                    <div class="table-responsive">
                                        <table id="tablaSolicitudesRevision" class="tabla-master table table-hover table-sm">
                                            <thead>
                                                <tr>
                                                    <th class="text-center">Acciones</th>
                                                    <th>Solicitante</th>
                                                    <th>Identificación</th>
                                                    <th>Celular</th>
                                                    <th>Fecha Solicitud</th>
                                                    <th>Monto</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @if (solicitudesRevi != null && solicitudesRevi.Any())
                                                {
                                                    @foreach (var solicitud in solicitudesRevi)
                                                    {
                                                        <tr>
                                                            <td class="text-center">
                                                                <div class="d-flex gap-1 justify-content-center">
                                                                    <button class="btn-accion-ver" title="Ver"
                                                                            onclick="verSolicitud(@solicitud.Id, @solicitud.EstadoId)">
                                                                        <i class="bi bi-eye-fill"></i>
                                                                    </button>
                                                                    <button class="btn-accion-aprobar" title="Aprobar"
                                                                            onclick="aprobarSolicitud(@solicitud.Id, @solicitud.EstadoId)">
                                                                        <i class="bi bi-check-circle-fill"></i>
                                                                    </button>
                                                                    <button class="btn-accion-rechazar" title="Cancelar"
                                                                            onclick="cancelarSolicitud(@solicitud.Id, @solicitud.EstadoId)">
                                                                        <i class="bi bi-x-circle-fill"></i>
                                                                    </button>
                                                                </div>
                                                            </td>
                                                            <td>@solicitud.NombreCompleto</td>
                                                            <td>@solicitud.NumeroIdentificacion.ToString("N0")</td>
                                                            <td>@solicitud.Celular</td>
                                                            <td>@solicitud.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</td>
                                                            <td>@(solicitud.Monto.ToString("C", new System.Globalization.CultureInfo("es-CO")) ?? "N/A")</td>
                                                        </tr>
                                                    }
                                                }
                                                else
                                                {
                                                    <tr>
                                                        <td colspan="6" class="tabla-vacia">
                                                            <i class="bi bi-inbox me-2"></i> No se encontraron solicitudes.
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/Soliciud/js/ValidarCod.js"></script>
    <script>
        function verSolicitud(id, estadoId) {
            window.location.href = '@Url.Action("Validar", "Solicitudes", new { Area = "Gestion" })'
                + '?id=' + id + '&estadoId=' + estadoId;
        }
    </script>
}
   