@{
    Layout = "_Layout";
    ViewData["Title"] = "Gestión de Préstamos";
}

<link href="~/lib/AprobacionPrestamo/css/Prestamos.css" rel="stylesheet" />

<div class="container-fluid py-3">
    <div class="row justify-content-center">
        <div class="col-lg-11">

            <!-- Header del módulo -->
            <div class="modulo-header">
                <h1>
                    <i class="bi bi-layout-text-window-reverse me-2"></i>
                    Gestión de Préstamos
                </h1>
                <p>Sistema de Préstamos Florencia</p>
            </div>

            <!-- Card Tabla Préstamos -->
            <div class="card-master">
                <div class="card-header-custom">
                    <i class="bi bi-cash-coin"></i>
                    <span>Préstamos Pendientes de Aprobación</span>
                </div>
                <div class="card-content">
                    <div class="table-responsive">
                        <table id="tablaPrestamos" class="tabla-master table table-hover table-sm">
                            <thead>
                                <tr>
                                    <th>Solicitante</th>
                                    <th>Identificación</th>
                                    <th>Celular</th>
                                    <th>Fecha Solicitud</th>
                                    <th>Monto</th>
                                    <th>Estado</th>
                                    <th class="text-center">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td colspan="7" class="tabla-vacia">
                                        <i class="bi bi-inbox me-2"></i>
                                        No se encontraron préstamos pendientes.
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/AprobacionPrestamo/AprobacionPrestamo.js"></script>
}
