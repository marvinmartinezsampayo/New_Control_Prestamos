@using Comun.DTO.Generales
@using Comun.DTO.Prestamo
@{
    Layout = "_Layout";
    ViewData["Title"] = "Consulta y Registro de Pagos";
}

<link href="~/lib/prestamo/css/pagos.css" rel="stylesheet" />

<div class="container py-3">
    <div class="row justify-content-center">
        <div class="col-lg-11">

            <!-- Header del módulo -->
            <div class="modulo-header">
                <h1>
                    <i class="bi bi-currency-exchange me-2"></i>
                    Consulta y Registro de Pagos
                </h1>
                <p>Sistema de Préstamos Florencia</p>
            </div>

            <!-- Alerta informativa -->
            <div class="alerta-info mb-3">
                <i class="bi bi-info-circle-fill"></i>
                Bienvenido al panel de consulta y registro de pagos. Aquí encontrarás un resumen
                de los préstamos y los aportes realizados por el cliente.
            </div>

            <!-- Card Buscar -->
            <div class="card-master">
                <div class="card-header-custom">
                    <i class="bi bi-search"></i>
                    <span>Consultar Préstamos del Cliente</span>
                </div>
                <div class="card-content">

                    <!-- Formulario búsqueda -->
                    <form method="get" action="~/Prestamo/Gestion/BuscarPorIdentificacion">
                        @Html.AntiForgeryToken()
                        <div class="row g-2 align-items-end mb-3">
                            <div class="col-12 col-md-9">
                                <label class="form-label-custom">Número de Identificación</label>
                                <input type="text" name="nroIdentificacion" class="form-input"
                                       placeholder="Buscar por identificación..." />
                            </div>
                            <div class="col-12 col-md-3">
                                <button class="btn-buscar w-100" type="submit">
                                    <i class="bi bi-search me-1"></i> Buscar
                                </button>
                            </div>
                        </div>
                    </form>

                    <!-- Resultados -->
                    @{
                        var listPres = ViewBag.Prestamos as List<Prestamo_Dto>;
                    }

                    @if (listPres != null && listPres.Any())
                    {
                        <!-- Alerta cliente encontrado -->
                        <div class="alerta-exito mb-3">
                            <i class="bi bi-person-check-fill"></i>
                            La identificación está asociada al usuario
                            <strong class="ms-1">@listPres[0].SOLICITANTE</strong>
                        </div>

                        <!-- Tabla préstamos -->
                        <div class="table-responsive">
                            <table id="datatablesSimple"
                                   class="tabla-master table table-hover table-sm">
                                <thead>
                                    <tr>
                                        <th class="text-center">Pagar</th>
                                        <th>Fecha Inicio</th>
                                        <th>Fecha Final</th>
                                        <th>Monto</th>
                                        <th>% Interés</th>
                                        <th>Cuotas</th>
                                        <th>Saldo</th>
                                        <th>Estado</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var solicitud in listPres)
                                    {
                                        <tr>
                                            <td class="text-center">
                                                <button class="btn-accion-aprobar" title="Registrar Pago"
                                                        onclick="pagarPrestamo(@solicitud.ID, @solicitud.MONTO, @solicitud.INTERES, @solicitud.SALDO_MONTO, @solicitud.NUMERO_CUOTAS)">
                                                    <i class="bi bi-currency-dollar"></i>
                                                </button>
                                            </td>
                                            <td>@solicitud.FECHA_INICIO.ToString("dd/MM/yyyy")</td>
                                            <td>@solicitud.FECHA_FIN.ToString("dd/MM/yyyy")</td>
                                            <td>@(solicitud.MONTO.ToString("C", new System.Globalization.CultureInfo("es-CO")) ?? "N/A")</td>
                                            <td>% @solicitud.INTERES.ToString()</td>
                                            <td>@solicitud.NUMERO_CUOTAS.ToString("N0")</td>
                                            <td>@(solicitud.SALDO_MONTO.ToString("C", new System.Globalization.CultureInfo("es-CO")) ?? "N/A")</td>
                                            <td>
                                                <span class="badge-estado badge-@(solicitud.ESTADO == "ACTIVO"     ? "aprobado"  :
                                                                                                                                         solicitud.ESTADO == "FINALIZADO" ? "finalizado" :
                                                                                                                                         solicitud.ESTADO == "MORA" ? "mora" : "rechazado")">
                                            @solicitud.ESTADO
                                        </span>
                                    </td>
                                </tr>
                                                                }
                                </tbody>
                            </table>
                        </div>
                    }

                </div>
            </div>

        </div>
    </div>
</div>


<!-- Modal Registrar Pago -->
<div class="modal fade" id="modalPagarPrestamo" tabindex="-1"
     aria-labelledby="modalPagarPrestamoLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content modal-master">

            <div class="modal-header-master">
                <h5 class="modal-titulo">
                    <i class="bi bi-credit-card me-2"></i> Registrar Pago de Préstamo
                </h5>
                <button type="button" class="btn-close btn-close-white"
                        data-bs-dismiss="modal"></button>
            </div>

            <form id="formPagarPrestamo">
                @Html.AntiForgeryToken()
                <div class="modal-body modal-body-master">
                    <div class="row g-3">

                        <!-- ID oculto -->
                        <div class="col-md-6 d-none">
                            <label class="form-label-custom">ID Préstamo</label>
                            <input type="number" class="form-input" id="idPrestamo"
                                   name="ID_PRESTAMO" readonly />
                        </div>

                        <!-- Fecha de pago -->
                        <div class="col-md-6">
                            <label class="form-label-custom">
                                Fecha de Pago <span class="campo-requerido">*</span>
                            </label>
                            <input type="datetime-local" class="form-input" id="fechaPago"
                                   name="FECHA_PAGO" required />
                        </div>

                        <!-- Monto -->
                        <div class="col-md-6">
                            <label class="form-label-custom">
                                Monto <span class="campo-requerido">*</span>
                            </label>
                            <div class="monto-wrapper">
                                <span class="monto-prefix">$</span>
                                <input type="text" class="form-input monto-input" id="monto"
                                       name="MONTO" placeholder="0" required />
                            </div>
                        </div>

                        <!-- Info distribución pago -->
                        <div class="col-12">
                            <div class="alerta-info">
                                <i class="bi bi-info-circle-fill"></i>
                                <div>
                                    El valor ingresado será distribuido entre pago de interés y luego en pago a capital.
                                    Interés: <strong id="valInteresPago"></strong> —
                                    Capital: <strong id="valCapitalPago"></strong> —
                                    Total: <strong id="valTotalPago"></strong>
                                </div>
                            </div>
                        </div>

                        <!-- Checkbox solo intereses -->
                        <div class="col-12">
                            <div class="switch-modal-wrapper">
                                <input class="switch-input" type="checkbox"
                                       id="checkSoloPagoInteres" />
                                <label class="switch-label" for="checkSoloPagoInteres">
                                    <i class="bi bi-toggle-on me-1"></i> Pagar solo intereses
                                </label>
                            </div>
                        </div>

                    </div>
                </div>

                <div class="modal-footer modal-footer-master">
                    <button type="button" class="btn-peligro" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle me-1"></i> Cancelar
                    </button>
                    <button type="submit" class="btn-exito">
                        <i class="bi bi-check-circle me-1"></i> Registrar Pago
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>

<div id="sweetAlertData"
     data-icon="@(TempData["SweetAlert"] ?? ViewBag.SweetAlert)"
     data-titulo="@(TempData["Titulo"] ?? ViewBag.Titulo)"
     data-mensaje="@(TempData["Mensaje"] ?? ViewBag.Mensaje)">
</div>

@section Scripts {
    <script src="~/lib/sweetalert2@11.js"></script>
    <script src="~/lib/prestamo/js/pago.js"></script>
}
