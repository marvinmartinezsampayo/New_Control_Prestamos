@using Comun.DTO.CodigoAcceso
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@{
    Layout = "_Layout";
    ViewData["Title"] = "Gestión de Códigos de Acceso";
}
<link href="~/lib/soliciud/css/CodigoAcceso.css" rel="stylesheet" />


<div class="container-fluid py-3">
    <div class="row justify-content-center">
        <div class="col-lg-11">

            <!-- Header del módulo -->
            <div class="modulo-header">
                <h1>
                    <i class="bi bi-pass-fill me-2"></i>
                    Generar Código de Acceso
                </h1>
                <p>Genera y administra los códigos de acceso del sistema</p>
            </div>

            <!-- Card Generar Código -->
            <div class="card-master">
                <div class="card-header-custom">
                    <i class="bi bi-magic"></i>
                    <span>Generar Nuevo Código</span>
                </div>
                <div class="card-content">
                    <form id="formGenerarCodigo">
                        <div class="row g-3 mb-3">
                            <div class="col-md-3">
                                <label class="form-label-custom">Código</label>
                                <input type="text" id="codigoGenerado" class="form-input"
                                       readonly placeholder="Se generará automáticamente" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label-custom">Fecha Inicio</label>
                                <input type="datetime-local" id="fechaInicio" class="form-input" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label-custom">Fecha Fin</label>
                                <input type="datetime-local" id="fechaFin" class="form-input" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label-custom">Cantidad Usos</label>
                                <input type="number" id="cantidadUsos" class="form-input" min="1"
                                       placeholder="ej: 10" />
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-3">
                                <button type="button" class="btn-generar w-100" onclick="generarCodigo()">
                                    <i class="bi bi-magic me-2"></i> Generar
                                </button>
                            </div>
                            <div class="col-md-3">
                                <button type="submit" class="btn-guardar w-100">
                                    <i class="bi bi-save me-2"></i> Guardar Código
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Card Buscar Códigos -->
            <div class="card-master">
                <div class="card-header-custom">
                    <i class="bi bi-search"></i>
                    <span>Buscar Códigos Generados</span>
                </div>
                <div class="card-content">
                    <form id="formBuscarCodigos">
                        <div class="row g-3 align-items-end">
                            <div class="col-md-3">
                                <label class="form-label-custom">Código a buscar</label>
                                <input type="text" id="codigoBuscar" class="form-input"
                                       placeholder="Digite el código..." />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label-custom">Fecha desde</label>
                                <input type="datetime-local" id="fechaDesde" class="form-input" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label-custom">Fecha hasta</label>
                                <input type="datetime-local" id="fechaHasta" class="form-input" />
                            </div>
                            <div class="col-md-2">
                                <button type="submit" class="btn-buscar w-100">
                                    <i class="bi bi-search me-1"></i> Buscar
                                </button>
                            </div>
                            <div class="col-md-1">
                                <button type="button" class="btn-limpiar w-100"
                                        onclick="limpiarBusqueda()">
                                    <i class="bi bi-x-circle"></i>
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Card Tabla de Resultados -->
            <div class="card-master">
                <div class="card-header-custom">
                    <i class="bi bi-table"></i>
                    <span>Códigos de Acceso Generados Hoy</span>
                </div>
                <div class="card-content">
                    <div class="table-responsive">
                        <table id="tablaCodigos" class="tabla-master table table-hover table-sm">
                            <thead>
                                <tr>
                                    <th>Código</th>
                                    <th>Fecha inicio</th>
                                    <th>Fecha fin</th>
                                    <th>Registros</th>
                                    <th>Usuario</th>
                                    <th>Estado</th>
                                    <th class="text-center">Ver</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td colspan="7" class="tabla-vacia">
                                        <i class="bi bi-inbox me-2"></i>
                                        No se encontraron códigos para hoy.
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>


<!-- Modal Editar Código -->
<div class="modal fade" id="modalEditarCodigo" tabindex="-1"
     aria-labelledby="modalEditarLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content modal-master">

            <div class="modal-header-master">
                <h5 class="modal-titulo">
                    <i class="bi bi-pencil-square me-2"></i> Editar Código de Acceso
                </h5>
                <button type="button" class="btn-close btn-close-white"
                        data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>

            <div class="modal-body modal-body-master">
                <form id="formEditarCodigo">
                    <input type="hidden" id="editId" />

                    <div class="mb-3">
                        <label class="form-label-custom">Código</label>
                        <input type="text" class="form-input" id="editCodigo" disabled />
                    </div>
                    <div class="mb-3">
                        <label class="form-label-custom">Fecha Inicio</label>
                        <input type="datetime-local" class="form-input" id="editFechaInicio" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label-custom">Cantidad Usos</label>
                        <input type="number" class="form-input" id="editcantidadUsos" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label-custom">Fecha Fin</label>
                        <input type="datetime-local" class="form-input" id="editFechaFin" />
                    </div>

                    <div class="switch-modal-wrapper">
                        <input class="switch-input" type="checkbox" id="editHabilitado" />
                        <label class="switch-label" for="editHabilitado">
                            <i class="bi bi-toggle-on me-1"></i> Habilitado
                        </label>
                    </div>
                </form>
            </div>

            <div class="modal-footer modal-footer-master">
                <button type="button" class="btn-peligro" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle me-1"></i> Cancelar
                </button>
                <button type="button" class="btn-exito" onclick="guardarEdicionCodigo()">
                    <i class="bi bi-save me-1"></i> Guardar cambios
                </button>
            </div>

        </div>
    </div>
</div>


<!-- SweetAlert data -->
<div id="sweetAlertData"
     data-icon="@(TempData["SweetAlert"] ?? ViewBag.SweetAlert)"
     data-titulo="@(TempData["Titulo"] ?? ViewBag.Titulo)"
     data-mensaje="@(TempData["Mensaje"] ?? ViewBag.Mensaje)"
     data-limpiar="@((ViewBag.LimpiarFormulario ?? false).ToString().ToLower())">
</div>

@section Scripts {
    <script src="~/lib/Soliciud/js/GenerarCodigoAcceso.js"></script>
    <script>
        const usuarioLogueado = {
            idUsuario:           '@User.FindFirst("IdUsuario")?.Value',
            nroIdentificacion:   '@User.FindFirst("Identificacion")?.Value',
            usuarioEmpresarial:  '@User.FindFirst("UsuarioEmpresarial")?.Value',
            email:               '@User.FindFirst("Email")?.Value',
            telefono:            '@User.FindFirst("Telefono")?.Value',
            ipMaquina:           '@User.FindFirst("Identificacion")?.Value',
            nombreCompleto:      '@User.FindFirst("NombreFull")?.Value',
            rol:                 '@User.FindFirst("RoleName")?.Value'
        };
        window.usuarioLogueado = usuarioLogueado;
    </script>
}
